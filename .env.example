# Copy to .env — never commit .env itself

# Database (MySQL — production)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=sporty
DB_USER=root
DB_PASSWORD=

# Analytics DB (local DuckDB)
DUCKDB_PATH=playbook.duckdb

# Data paths
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed

# A/B testing
AB_ALPHA=0.05

# Logging
LOG_LEVEL=INFO
